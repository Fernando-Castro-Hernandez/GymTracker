# Plantilla de variables de entorno. Copia este archivo a .env y pon tus valores.
#   Windows PowerShell:  Copy-Item .env.example .env
#   Bash / macOS / Linux: cp .env.example .env
#
# .env NO se versiona (está en .gitignore). Este .example sí, como guía.

# Contraseña de PostgreSQL para desarrollo local (docker-compose la usa al crear el contenedor).
POSTGRES_PASSWORD=cambia_esta_contrasena

# NOTA: el contenedor se publica en el puerto 5433 del host (ver docker-compose.yml),
# para no chocar con un PostgreSQL nativo que use el 5432. La connection string de
# la app debe apuntar a Port=5433 (se configura por User Secrets, ver README).
