@model GymTracker.Models.Rutina

@{
    ViewData["Title"] = "Agregar Rutina";
}

<div class="container mt-4" style="max-width: 700px;">
    <h1>Crear Rutina</h1>
    <p class="text-muted">Por ahora solo podrás crear la rutina con nombre y descripción. La asignación de ejercicios estará disponible próximamente.</p>

    <form asp-action="Agregar" method="post" class="mt-4">
        <div class="mb-3">
            <label asp-for="Nombre" class="form-label">Nombre</label>
            <input asp-for="Nombre" class="form-control"
                   placeholder="Ej. Push - Lunes" required maxlength="100" />
        </div>

        <div class="mb-3">
            <label asp-for="Descripcion" class="form-label">Descripción (opcional)</label>
            <textarea asp-for="Descripcion" class="form-control" rows="3"
                      placeholder="Ej. Día de pecho, hombro y tríceps. Enfoque en compuestos."></textarea>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            <button type="submit" class="btn btn-primary">Crear Rutina</button>
        </div>
    </form>
</div>