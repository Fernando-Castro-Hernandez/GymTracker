@model GymTracker.Models.Rutina

@{
    ViewData["Title"] = $"Rutina - {Model.Nombre}";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1>@Model.Nombre</h1>
            <p class="text-muted">
                Creada el @Model.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
            </p>
        </div>
        <div>
            <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
            <a asp-action="Eliminar" asp-route-id="@Model.Id" class="btn btn-danger">Eliminar</a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Descripcion))
    {
        <div class="card mb-4">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted">Descripción</h6>
                <p class="card-text">@Model.Descripcion</p>
            </div>
        </div>
    }

    <h3>Ejercicios de esta rutina</h3>

    @if (!Model.Ejercicios.Any())
    {
        <div class="alert alert-warning">
            Esta rutina no tiene ejercicios asignados todavía.
            La asignación de ejercicios estará disponible en la siguiente versión.
        </div>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Ejercicio</th>
                    <th>Grupo</th>
                    <th class="text-center">Series</th>
                    <th class="text-center">Reps</th>
                    <th class="text-end">Peso (kg)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Ejercicios.OrderBy(e => e.Orden))
                {
                    <tr>
                        <td>@(Model.Ejercicios.ToList().IndexOf(item) + 1)</td>
                        <td><strong>@item.Ejercicio.Nombre</strong></td>
                        <td><span class="badge bg-secondary">@item.Ejercicio.GrupoMuscular</span></td>
                        <td class="text-center">@item.SeriesObjetivo</td>
                        <td class="text-center">@item.RepeticionesObjetivo</td>
                        <td class="text-end">@item.PesoObjetivo.ToString("0.##")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-secondary">&larr; Volver a Mis Rutinas</a>
    </div>
</div>