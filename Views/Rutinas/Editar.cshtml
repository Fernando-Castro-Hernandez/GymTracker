@model GymTracker.Models.Rutina

@{
    ViewData["Title"] = "Editar Rutina";
}

<div class="container mt-4" style="max-width: 700px;">
    <h1 class="page-title section-accent mb-4">Editar rutina</h1>

    <div class="card">
        <div class="card-body">
            <form asp-action="Editar" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label">Nombre</label>
                    <input asp-for="Nombre" class="form-control" required maxlength="100" />
                </div>

                <div class="mb-4">
                    <label asp-for="Descripcion" class="form-label">Descripción (opcional)</label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Guardar cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>
