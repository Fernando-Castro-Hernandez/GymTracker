@model GymTracker.Models.ViewModels.RegistrarSesionViewModel

@{
    ViewData["Title"] = "Registrar entrenamiento";
    var grupos = Model.Series
        .GroupBy(s => s.NombreEjercicio)
        .ToList();
}

<div class="container mt-4" style="max-width: 900px;">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3">&larr; Volver al historial</a>

    <h1 class="page-title section-accent mb-1">@Model.NombreRutina</h1>
    <p class="page-subtitle">
        Entrenamiento del @Model.Fecha.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
    </p>
    <p class="text-muted mb-4">
        Ajusta las repeticiones y el peso que realmente hiciste en cada serie.
        Los valores ya vienen con tu meta; solo cambia lo que sea diferente.
    </p>

    <form asp-action="Registrar" method="post">
        <input type="hidden" asp-for="SesionId" />

        @{
            var indiceGlobal = 0;
        }

        @foreach (var grupo in grupos)
        {
            var primera = grupo.First();
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        @if (!string.IsNullOrEmpty(primera.GifUrl))
                        {
                            <img src="@primera.GifUrl" alt="@grupo.Key"
                                 class="gt-serie-gif js-abrir-gif"
                                 data-gif="@primera.GifUrl" data-nombre="@grupo.Key"
                                 title="Ver animación" loading="lazy"
                                 onerror="this.remove()" />
                        }
                        <strong>@grupo.Key</strong>
                    </div>
                    <span class="gt-badge-grupo" data-grupo="@primera.GrupoMuscular">@primera.GrupoMuscular</span>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Serie</th>
                                <th class="text-center">Meta</th>
                                <th class="text-center">Reps reales</th>
                                <th class="text-center">Peso real (kg)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var serie in grupo)
                            {
                                var i = indiceGlobal;
                                <tr>
                                    <td class="text-muted">#@serie.NumeroSerie</td>
                                    <td class="text-center text-muted">
                                        @serie.RepeticionesObjetivo reps &times; @serie.PesoObjetivo.ToString("0.##") kg
                                    </td>
                                    <td class="text-center">
                                        <input type="hidden" name="Series[@i].Id" value="@serie.Id" />
                                        <input type="number" name="Series[@i].RepeticionesReales"
                                               value="@serie.RepeticionesReales"
                                               class="form-control text-center mx-auto" style="max-width: 100px;"
                                               min="0" max="999" required />
                                    </td>
                                    <td class="text-center">
                                        <input type="number" name="Series[@i].PesoReal"
                                               value="@serie.PesoReal.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"
                                               class="form-control text-center mx-auto" style="max-width: 120px;"
                                               min="0" max="9999" step="0.01" required />
                                    </td>
                                </tr>
                                indiceGlobal++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <div class="card mb-4">
            <div class="card-body">
                <label asp-for="Notas" class="form-label">Notas del entrenamiento (opcional)</label>
                <textarea asp-for="Notas" class="form-control" rows="2"
                          placeholder="Ej: me senti fuerte, subi peso en press..."></textarea>
            </div>
        </div>

        <div class="d-flex justify-content-between mb-5">
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            <button type="submit" class="btn btn-success">Guardar entrenamiento</button>
        </div>
    </form>
</div>

<!-- Modal: animación del ejercicio (GIF grande) -->
<div class="modal fade" id="modalGif" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-capitalize" id="modalGifTitulo"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body text-center">
                <img id="modalGifImg" src="" alt="" class="gt-cat-detalle-gif" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const modalEl = document.getElementById('modalGif');
            if (!modalEl) return;
            const modal = new bootstrap.Modal(modalEl);
            const img = document.getElementById('modalGifImg');
            const titulo = document.getElementById('modalGifTitulo');

            document.querySelectorAll('.js-abrir-gif').forEach(el => {
                el.addEventListener('click', () => {
                    img.src = el.dataset.gif;
                    img.alt = el.dataset.nombre || '';
                    titulo.textContent = el.dataset.nombre || 'Animación';
                    modal.show();
                });
            });
        })();
    </script>
}
