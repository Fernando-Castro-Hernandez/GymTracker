@model List<GymTracker.Models.Ejercicio>
@using GymTracker.Models.Enums

@{
    ViewData["Title"] = "Mis Ejercicios";
    var grupos = ViewBag.Grupos as string[];
    var grupoActual = ViewBag.GrupoActual as string;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Mis Ejercicios</h1>
        <a asp-action="Agregar" class="btn btn-primary">+ Agregar Ejercicio</a>
    </div>

    <!-- Filtros por grupo muscular -->
    <div class="mb-4">
        <a asp-action="Index"
               class="btn btn-sm @(string.IsNullOrEmpty(grupoActual) ? "btn-dark" : "btn-outline-dark")">
            Todos
        </a>
        @if (grupos != null)
        {
            foreach (var g in grupos)
            {
                <a asp-action="Index" asp-route-grupo="@g"
                       class="btn btn-sm @(grupoActual == g ? "btn-dark" : "btn-outline-dark")">
                    @g
                </a>
            }
        }
    </div>

    <!-- Lista de ejercicios -->
    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No tienes ejercicios todavía. ¡Agrega el primero!
        </div>
    }
    else
    {
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Grupo Muscular</th>
                    <th>Descripción</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ejercicio in Model)
                {
                    <tr>
                        <td><strong>@ejercicio.Nombre</strong></td>
                        <td>
                            <span class="badge bg-secondary">@ejercicio.GrupoMuscular</span>
                        </td>
                        <td>@(ejercicio.Descripcion ?? "—")</td>
                        <td class="text-end">
                            <a asp-action="Detalle" asp-route-id="@ejercicio.Id"
                               class="btn btn-sm btn-outline-primary">Ver</a>
                            <a asp-action="Editar" asp-route-id="@ejercicio.Id"
                               class="btn btn-sm btn-outline-secondary">Editar</a>
                            <a asp-action="Eliminar" asp-route-id="@ejercicio.Id"
                               class="btn btn-sm btn-outline-danger">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>