@model List<GymTracker.Models.Ejercicio>
@using GymTracker.Models.Enums

@{
    ViewData["Title"] = "Mis Ejercicios";
    var grupos = ViewBag.Grupos as string[];
    var grupoActual = ViewBag.GrupoActual as string;
}

<div class="container mt-4">
    <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-title section-accent">Mis Ejercicios</h1>
            <p class="page-subtitle">Tu catálogo personal de ejercicios por grupo muscular.</p>
        </div>
        <a asp-action="Agregar" class="btn btn-primary">+ Agregar ejercicio</a>
    </div>

    <!-- Filtros por grupo muscular -->
    <div class="d-flex flex-wrap gap-2 mb-4">
        <a asp-action="Index"
               class="btn btn-sm @(string.IsNullOrEmpty(grupoActual) ? "btn-dark" : "btn-outline-dark")">
            Todos
        </a>
        @if (grupos != null)
        {
            foreach (var g in grupos)
            {
                <a asp-action="Index" asp-route-grupo="@g"
                       class="btn btn-sm @(grupoActual == g ? "btn-dark" : "btn-outline-dark")">
                    @g
                </a>
            }
        }
    </div>

    <!-- Lista de ejercicios -->
    @if (!Model.Any())
    {
        <div class="gt-empty">
            <div class="gt-empty-icon">🏋️</div>
            <h5>No tienes ejercicios todavía</h5>
            <p>Empieza creando tu primer ejercicio para poder armar rutinas con él.</p>
            <a asp-action="Agregar" class="btn btn-primary">+ Agregar mi primer ejercicio</a>
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Grupo muscular</th>
                            <th>Descripción</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ejercicio in Model)
                        {
                            <tr>
                                <td><strong>@ejercicio.Nombre</strong></td>
                                <td>
                                    <span class="gt-badge-grupo" data-grupo="@ejercicio.GrupoMuscular">@ejercicio.GrupoMuscular</span>
                                </td>
                                <td class="text-muted">@(ejercicio.Descripcion ?? "—")</td>
                                <td class="text-end">
                                    <div class="gt-acciones justify-content-end">
                                        <a asp-action="Detalle" asp-route-id="@ejercicio.Id"
                                           class="gt-accion" title="Ver">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                <circle cx="12" cy="12" r="3" />
                                            </svg>
                                        </a>
                                        <a asp-action="Editar" asp-route-id="@ejercicio.Id"
                                           class="gt-accion" title="Editar">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                                <path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                            </svg>
                                        </a>
                                        <a asp-action="Eliminar" asp-route-id="@ejercicio.Id"
                                           class="gt-accion gt-accion-danger" title="Eliminar">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="3 6 5 6 21 6" />
                                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                            </svg>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
