@model GymTracker.Models.Ejercicio

@{
    ViewData["Title"] = "Eliminar Ejercicio";
}

<div class="container mt-4">
    <div class="card border-danger">
        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">¿Estás seguro de eliminar este ejercicio?</h3>
        </div>
        <div class="card-body">
            <p>Esta acción no se puede deshacer.</p>

            <dl class="row">
                <dt class="col-sm-3">Nombre</dt>
                <dd class="col-sm-9">@Model.Nombre</dd>

                <dt class="col-sm-3">Grupo Muscular</dt>
                <dd class="col-sm-9">@Model.GrupoMuscular</dd>

                <dt class="col-sm-3">Descripción</dt>
                <dd class="col-sm-9">@(Model.Descripcion ?? "Sin descripción")</dd>
            </dl>
        </div>
        <div class="card-footer d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            <form asp-action="Eliminar" method="post" class="d-inline">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger">Sí, eliminar</button>
            </form>
        </div>
    </div>
</div>