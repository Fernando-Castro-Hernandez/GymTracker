@model List<GymTracker.Services.Catalogo.EjercicioCatalogoDto>
@{
    ViewData["Title"] = "Explorar ejercicios";
    var bodyParts = ViewBag.BodyParts as List<string> ?? new List<string>();
    var activo = ViewBag.BodyPartActivo as string;
    var nextCursor = ViewBag.NextCursor as string;
}

<div class="container mt-4">
    <h1 class="page-title section-accent mb-1">Explorar ejercicios</h1>
    <p class="page-subtitle mb-4">
        Catálogo con animaciones para aprender la ejecución de cada movimiento.
    </p>

    <div class="gt-catalogo-filtros">
        <a asp-action="Index" class="btn btn-sm @(activo == null ? "btn-primary" : "btn-secondary")">Todos</a>
        @foreach (var bp in bodyParts)
        {
            <a asp-action="Index" asp-route-bodyPart="@bp"
               class="btn btn-sm @(activo == bp ? "btn-primary" : "btn-secondary") text-capitalize">@bp</a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-muted text-center py-5">
            No se encontraron ejercicios para este filtro.
        </div>
    }
    else
    {
        <div class="gt-catalogo-grid">
            @foreach (var ej in Model)
            {
                <div class="gt-cat-card-wrap">
                    <a asp-action="Detalle" asp-route-id="@ej.ExerciseId" class="gt-cat-card">
                        <img src="@ej.GifUrl" alt="@ej.Name" class="gt-cat-gif" loading="lazy"
                             onerror="this.onerror=null; this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22100%22 height=%22100%22%3E%3Crect fill=%22%23eee%22 width=%22100%22 height=%22100%22/%3E%3Ctext x=%2250%22 y=%2250%22 fill=%22%23999%22 font-size=%228%22 text-anchor=%22middle%22 dy=%22.3em%22%3ESin animaci%C3%B3n%3C/text%3E%3C/svg%3E';" />
                        <div class="gt-cat-body">
                            <div class="gt-cat-nombre">@ej.Name</div>
                            <div class="gt-cat-meta">
                                @foreach (var m in ej.TargetMuscles.Take(2))
                                {
                                    <span class="gt-cat-chip">@m</span>
                                }
                            </div>
                        </div>
                    </a>
                    <button type="button" class="gt-cat-vincular"
                            data-exid="@ej.ExerciseId" data-nombre="@ej.Name"
                            title="Vincular a mis ejercicios">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
                        </svg>
                        <span>Vincular</span>
                    </button>
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(nextCursor))
        {
            var urlVerMas = string.IsNullOrEmpty(activo)
                ? $"/Catalogo?cursor={nextCursor}"
                : $"/Catalogo?bodyPart={activo}&cursor={nextCursor}";
            <div class="text-center mt-4">
                <a href="@urlVerMas" class="btn btn-secondary">Ver más ejercicios</a>
            </div>
        }
    }
</div>

<!-- Modal: elegir a cuál de mis ejercicios vincular -->
<div class="modal fade" id="modalVincular" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Vincular a mis ejercicios</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">
                    Vas a vincular <strong id="vinculoCatNombre" class="text-capitalize"></strong>
                    a uno de tus ejercicios. Su animación aparecerá al entrenar.
                </p>
                <div id="vinculoSinEjercicios" class="text-muted d-none">
                    Todavía no tienes ejercicios.
                    <a asp-controller="Ejercicios" asp-action="Agregar">Crea uno primero</a>.
                </div>
                <div id="vinculoPicker">
                    <label class="form-label" for="vinculoSelect">Tu ejercicio</label>
                    <select id="vinculoSelect" class="form-select"></select>
                </div>
                <div id="vinculoError" class="text-danger small mt-2 d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="vinculoConfirmar">Vincular</button>
            </div>
        </div>
    </div>
</div>

<div id="vinculoToast" class="gt-toast d-none" role="status"></div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        (function () {
            const tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
            const token = tokenEl ? tokenEl.value : '';
            const modalEl = document.getElementById('modalVincular');
            const modal = new bootstrap.Modal(modalEl);
            const select = document.getElementById('vinculoSelect');
            const catNombre = document.getElementById('vinculoCatNombre');
            const errBox = document.getElementById('vinculoError');
            const picker = document.getElementById('vinculoPicker');
            const sinEj = document.getElementById('vinculoSinEjercicios');
            const confirmar = document.getElementById('vinculoConfirmar');
            const toast = document.getElementById('vinculoToast');

            let misEjercicios = null;   // se carga una vez
            let exidActual = null;

            const esc = s => String(s).replace(/[&<>"]/g, c =>
                ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

            async function cargarMios() {
                if (misEjercicios) return misEjercicios;
                const r = await fetch('/Ejercicios/Mios');
                misEjercicios = await r.json();
                return misEjercicios;
            }

            function mostrarToast(msg) {
                toast.textContent = msg;
                toast.classList.remove('d-none');
                clearTimeout(toast._t);
                toast._t = setTimeout(() => toast.classList.add('d-none'), 2600);
            }

            document.querySelectorAll('.gt-cat-vincular').forEach(btn => {
                btn.addEventListener('click', async () => {
                    exidActual = btn.dataset.exid;
                    catNombre.textContent = btn.dataset.nombre;
                    errBox.classList.add('d-none');

                    const mios = await cargarMios();
                    if (!mios.length) {
                        picker.classList.add('d-none');
                        sinEj.classList.remove('d-none');
                        confirmar.classList.add('d-none');
                    } else {
                        picker.classList.remove('d-none');
                        sinEj.classList.add('d-none');
                        confirmar.classList.remove('d-none');
                        select.innerHTML = mios.map(e =>
                            `<option value="${e.id}">${esc(e.nombre)}${e.exerciseDbId ? ' · ya vinculado' : ''}</option>`
                        ).join('');
                    }
                    modal.show();
                });
            });

            confirmar.addEventListener('click', async () => {
                const ejercicioId = select.value;
                if (!ejercicioId) return;

                confirmar.disabled = true;
                errBox.classList.add('d-none');
                try {
                    const body = new URLSearchParams({
                        ejercicioId: ejercicioId,
                        exerciseDbId: exidActual,
                        __RequestVerificationToken: token
                    });
                    const r = await fetch('/Ejercicios/Vincular', { method: 'POST', body });
                    const data = await r.json();
                    if (r.ok && data.ok) {
                        const e = misEjercicios.find(x => x.id == ejercicioId);
                        if (e) e.exerciseDbId = exidActual;   // reflejar en memoria
                        modal.hide();
                        mostrarToast('Vinculado a "' + data.nombre + '"');
                    } else {
                        errBox.textContent = data.error || 'No se pudo vincular.';
                        errBox.classList.remove('d-none');
                    }
                } catch {
                    errBox.textContent = 'Error de red al vincular.';
                    errBox.classList.remove('d-none');
                } finally {
                    confirmar.disabled = false;
                }
            });
        })();
    </script>
}
