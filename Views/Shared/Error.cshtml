@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container" style="max-width: 720px;">
    <div class="card border-danger">
        <div class="card-body text-center py-5">
            <div class="gt-empty-icon">⚠️</div>
            <h1 class="text-danger">Algo salió mal</h1>
            <p class="text-muted">Ocurrió un error al procesar tu solicitud.</p>

            @if (Model.ShowRequestId)
            {
                <p class="mb-0">
                    <strong>ID de la solicitud:</strong> <code>@Model.RequestId</code>
                </p>
            }
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-body">
            <h3 class="h5">Modo de desarrollo</h3>
            <p class="text-muted mb-2">
                Cambiar al entorno de <strong>Development</strong> muestra información más
                detallada sobre el error ocurrido.
            </p>
            <p class="text-muted mb-0">
                <strong>El entorno de desarrollo no debe estar habilitado en aplicaciones desplegadas.</strong>
                Puede exponer información sensible de las excepciones a los usuarios finales.
                Para depurar localmente, habilita el entorno <strong>Development</strong> asignando la
                variable de entorno <strong>ASPNETCORE_ENVIRONMENT</strong> a <strong>Development</strong>
                y reiniciando la aplicación.
            </p>
        </div>
    </div>
</div>
