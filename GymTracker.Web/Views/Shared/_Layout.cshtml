@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@{
    // Helper de estado activo: marca el enlace del controlador actual.
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    string NavActive(string controller) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";

    // La pantalla de carga (Lottie) SOLO se muestra al entrar a la lista
    // principal de cada sección (el Index de los controladores de la navbar),
    // no en subpáginas como Crear/Editar/Detalles/Registrar. Antes aparecía en
    // toda navegación —al vivir en el layout compartido— y con 3 s por vista se
    // volvía molesta. Aquí el overlay ni siquiera se renderiza fuera de esas
    // páginas, así que no hay nada que ocultar.
    var seccionesConLoader = new[]
    {
        "Home", "Ejercicios", "Rutinas", "Sesiones", "Mediciones", "Progreso", "Catalogo"
    };
    var mostrarLoader =
        currentAction is not null &&
        string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase) &&
        seccionesConLoader.Contains(currentController, StringComparer.OrdinalIgnoreCase);
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GymTracker</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GymTracker.styles.css" asp-append-version="true" />
</head>
<body>
    @* Pantalla de carga (Lottie): overlay a pantalla completa. Solo se renderiza
       en el índice de las secciones principales (ver `mostrarLoader` arriba), no
       en cada navegación. La lógica vive en site.js; el estilo en site.css.
       Es puramente visual. *@
    @if (mostrarLoader)
    {
        <div id="gt-loader" class="gt-loader" aria-hidden="true">
            <div id="gt-loader-anim" class="gt-loader-anim"></div>
        </div>
    }

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm gt-navbar mb-4">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">▰</span>
                    <span>Gym<span class="brand-accent">Tracker</span></span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link @NavActive("Home")" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Ejercicios")" asp-area="" asp-controller="Ejercicios" asp-action="Index">Ejercicios</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Rutinas")" asp-area="" asp-controller="Rutinas" asp-action="Index">Rutinas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Sesiones")" asp-area="" asp-controller="Sesiones" asp-action="Index">Historial</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Mediciones")" asp-area="" asp-controller="Mediciones" asp-action="Index">Mediciones</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Progreso")" asp-area="" asp-controller="Progreso" asp-action="Index">Progreso</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @NavActive("Catalogo")" asp-area="" asp-controller="Catalogo" asp-action="Index">Explorar</a>
                            </li>
                        }
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - GymTracker - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacidad</a>
        </div>
    </footer>

    @* Chatbot con contexto (Integración 4): solo para usuarios autenticados. *@
    @if (SignInManager.IsSignedIn(User))
    {
        <partial name="_ChatWidget" />
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/lottie/lottie.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
