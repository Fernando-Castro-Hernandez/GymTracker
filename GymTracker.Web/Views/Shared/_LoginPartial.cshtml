@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav align-items-sm-center">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Manage/Index" title="Administrar cuenta">
            <span class="brand-mark">●</span> @User.Identity?.Name
        </a>
    </li>
    <li class="nav-item ms-sm-2">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="btn btn-sm btn-outline-secondary">Salir</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Iniciar sesión</a>
    </li>
    <li class="nav-item ms-sm-2">
        <a class="btn btn-sm btn-primary" asp-area="Identity" asp-page="/Account/Register">Registrarse</a>
    </li>
}
</ul>
