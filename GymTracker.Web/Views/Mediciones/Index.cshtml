@model List<GymTracker.Models.Medicion>

@{
    ViewData["Title"] = "Mediciones corporales";

    // Helper local para mostrar un valor opcional o un guion si es null.
    Func<decimal?, string> v = (x) => x.HasValue ? x.Value.ToString("0.##") : "—";
}

<div class="container mt-4">
    <div class="d-flex flex-wrap gap-3 justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-title section-accent mb-1">Mediciones corporales</h1>
            <p class="page-subtitle mb-0">Tu progreso físico a lo largo del tiempo.</p>
        </div>
        <a asp-action="Crear" class="btn btn-success">+ Nueva medición</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Aún no has registrado ninguna medición. Presiona
            <strong>"Nueva medición"</strong> para empezar a seguir tu progreso.
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th class="text-center">Peso (kg)</th>
                            <th class="text-center">% Grasa</th>
                            <th class="text-center">M. muscular</th>
                            <th class="text-center">Cintura</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Model)
                        {
                            <tr>
                                <td><strong>@m.Fecha.ToLocalTime().ToString("dd/MM/yyyy")</strong></td>
                                <td class="text-center">@m.Peso.ToString("0.##")</td>
                                <td class="text-center">@v(m.PorcentajeGrasa)</td>
                                <td class="text-center">@v(m.MasaMuscular)</td>
                                <td class="text-center">@v(m.Cintura)</td>
                                <td class="text-end">
                                    <div class="gt-acciones justify-content-end">
                                        <a asp-action="Detalle" asp-route-id="@m.Id" class="gt-accion" title="Ver">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                <circle cx="12" cy="12" r="3" />
                                            </svg>
                                        </a>
                                        <a asp-action="Editar" asp-route-id="@m.Id" class="gt-accion" title="Editar">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                                <path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                            </svg>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>