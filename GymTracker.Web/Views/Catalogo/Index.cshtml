@{
    ViewData["Title"] = "Explorar ejercicios";
}

<div class="container mt-4">
    <h1 class="page-title section-accent mb-1">Explorar ejercicios</h1>
    <p class="page-subtitle mb-4">
        Catálogo con animaciones para aprender la ejecución de cada movimiento.
    </p>

    <div class="gt-filtros">
        <div class="gt-filtros-buscar">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="7" />
                <line x1="21" y1="21" x2="16.65" y2="16.65" />
            </svg>
            <input id="fx-buscar" type="search" autocomplete="off" placeholder="Buscar ejercicio por nombre…" />
        </div>

        <div class="gt-filtros-seccion">
            <span class="gt-filtros-label">Zona</span>
            <div id="fx-zonas" class="gt-pills"></div>
        </div>

        <div id="fx-submusculo-wrap" class="gt-filtros-seccion d-none">
            <span class="gt-filtros-label">Músculo</span>
            <div id="fx-submusculo" class="gt-pills"></div>
        </div>

        <button type="button" id="fx-toggle-mas" class="gt-filtros-mas" aria-expanded="false">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="4" y1="6" x2="20" y2="6" />
                <line x1="7" y1="12" x2="17" y2="12" />
                <line x1="10" y1="18" x2="14" y2="18" />
            </svg>
            <span>Más filtros</span>
        </button>

        <div id="fx-panel-mas" class="gt-filtros-panel">
            <div class="gt-filtros-panel-inner">
                <div class="gt-filtros-seccion">
                    <span class="gt-filtros-label">Equipamiento</span>
                    <div id="fx-equipos" class="gt-pills"></div>
                </div>
                <div class="gt-filtros-seccion mb-0">
                    <span class="gt-filtros-label">Patrón de movimiento</span>
                    <div id="fx-patrones" class="gt-pills"></div>
                </div>
            </div>
        </div>

        <div id="fx-activos" class="gt-filtros-activos"></div>
    </div>

    <div id="fx-resultados-info" class="gt-resultados-info"></div>

    <div id="fx-cargando" class="text-muted text-center py-5">Cargando catálogo…</div>
    <div id="fx-vacio" class="text-muted text-center py-5 d-none">
        No se encontraron ejercicios con estos filtros.
    </div>

    <div id="fx-grid" class="gt-catalogo-grid"></div>

    <div id="fx-vermas-wrap" class="text-center mt-4 d-none">
        <button type="button" id="fx-vermas" class="btn btn-secondary">Ver más ejercicios</button>
    </div>
</div>

<!-- Modal: elegir a cuál de mis ejercicios vincular -->
<div class="modal fade" id="modalVincular" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Vincular a mis ejercicios</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">
                    Vas a vincular <strong id="vinculoCatNombre" class="text-capitalize"></strong>
                    a uno de tus ejercicios. Su animación aparecerá al entrenar.
                </p>
                <div id="vinculoSinEjercicios" class="text-muted d-none">
                    Todavía no tienes ejercicios.
                    <a asp-controller="Ejercicios" asp-action="Agregar">Crea uno primero</a>.
                </div>
                <div id="vinculoPicker">
                    <label class="form-label" for="vinculoSelect">Tu ejercicio</label>
                    <select id="vinculoSelect" class="form-select"></select>
                </div>
                <div id="vinculoError" class="text-danger small mt-2 d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="vinculoConfirmar">Vincular</button>
            </div>
        </div>
    </div>
</div>

<div id="vinculoToast" class="gt-toast d-none" role="status"></div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="~/js/catalogo-explorar.js" asp-append-version="true"></script>
}
