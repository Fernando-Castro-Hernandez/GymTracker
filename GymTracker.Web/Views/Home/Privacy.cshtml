@{
    ViewData["Title"] = "Política de privacidad";
}

<div class="container" style="max-width: 760px;">
    <h1 class="page-title section-accent mb-4">@ViewData["Title"]</h1>

    <div class="card">
        <div class="card-body">
            <p class="mb-0 text-muted">
                GymTracker es un proyecto académico personal. Los datos que
                registres (ejercicios y rutinas) se almacenan únicamente para
                tu propia cuenta y no se comparten con terceros.
            </p>
        </div>
    </div>
</div>
