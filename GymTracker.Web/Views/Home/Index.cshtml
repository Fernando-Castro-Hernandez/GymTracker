@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@{
    ViewData["Title"] = "Inicio";
    var signedIn = SignInManager.IsSignedIn(User);
}

@if (signedIn)
{
    <section class="gt-hero-logged">
        <div class="gt-hero-text">
            <span class="gt-eyebrow">Tu bitácora de fuerza</span>
            <h1>Cada serie<br /><span class="gt-hero-accent">cuenta.</span></h1>
            <p>
                El progreso no se adivina, se mide. Registra lo que levantas,
                observa cómo sube y deja que los números confirmen tu esfuerzo.
            </p>
        </div>

        <a asp-controller="Rutinas" asp-action="Index" class="gt-entrenar">
            <span class="gt-entrenar-arrow">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="7" y1="17" x2="17" y2="7" />
                    <polyline points="7 7 17 7 17 17" />
                </svg>
            </span>
            <span class="gt-entrenar-title">Entrenar</span>
            <p class="gt-entrenar-desc">Elige una rutina e inicia tu sesión de hoy.</p>
        </a>
    </section>

    <h2 class="page-title section-accent mb-3" style="font-size: 1.3rem;">Accesos rápidos</h2>
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-lg-3">
            <a asp-controller="Ejercicios" asp-action="Index" class="gt-nav-card">
                <span class="gt-nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2 9v6M22 9v6M6.5 5v14M17.5 5v14M6.5 12h11" />
                    </svg>
                </span>
                <span>
                    <span class="gt-nav-title">Ejercicios</span>
                    <p class="gt-nav-desc">Tu catálogo por grupo muscular</p>
                </span>
            </a>
        </div>
        <div class="col-md-6 col-lg-3">
            <a asp-controller="Sesiones" asp-action="Index" class="gt-nav-card">
                <span class="gt-nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 3v18h18" />
                        <path d="M7 14l4-4 3 3 5-6" />
                    </svg>
                </span>
                <span>
                    <span class="gt-nav-title">Historial</span>
                    <p class="gt-nav-desc">Tus sesiones registradas</p>
                </span>
            </a>
        </div>
        <div class="col-md-6 col-lg-3">
            <a asp-controller="Mediciones" asp-action="Index" class="gt-nav-card">
                <span class="gt-nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2 12h20" />
                        <path d="M6 8v8M10 6v12M14 8v8M18 6v12" />
                    </svg>
                </span>
                <span>
                    <span class="gt-nav-title">Mediciones</span>
                    <p class="gt-nav-desc">Peso y medidas corporales</p>
                </span>
            </a>
        </div>
        <div class="col-md-6 col-lg-3">
            <a asp-controller="Progreso" asp-action="Index" class="gt-nav-card">
                <span class="gt-nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 3v18h18" />
                        <path d="M19 9l-5 5-4-4-3 3" />
                    </svg>
                </span>
                <span>
                    <span class="gt-nav-title">Progreso</span>
                    <p class="gt-nav-desc">Tus gráficas de fuerza y peso</p>
                </span>
            </a>
        </div>
    </div>
}
else
{
    <section class="gt-hero mb-5">
        <span class="gt-eyebrow">Sobrecarga progresiva</span>
        <h1>
            Registra tu entrenamiento.<br />
            <span class="gt-hero-accent">Mide tu progreso.</span>
        </h1>
        <p class="lead mb-4">
            GymTracker es tu bitácora de gimnasio: arma tu catálogo de ejercicios,
            diseña rutinas con metas de series, repeticiones y peso, y lleva el
            control real de tu fuerza con el tiempo.
        </p>
        <div class="d-flex flex-wrap gap-2">
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-lg">Empezar ahora</a>
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-secondary btn-lg">Iniciar sesión</a>
        </div>
    </section>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card gt-feature">
                <div class="card-body">
                    <div class="gt-feature-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M2 9v6M22 9v6M6.5 5v14M17.5 5v14M6.5 12h11" />
                        </svg>
                    </div>
                    <h5 class="card-title">Catálogo de ejercicios</h5>
                    <p class="text-muted mb-0">
                        Crea tu biblioteca personal de ejercicios y organízalos por
                        grupo muscular para encontrarlos al instante.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card gt-feature">
                <div class="card-body">
                    <div class="gt-feature-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 11l3 3L22 4" />
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                        </svg>
                    </div>
                    <h5 class="card-title">Rutinas con metas</h5>
                    <p class="text-muted mb-0">
                        Diseña rutinas combinando tus ejercicios con objetivos claros
                        de series, repeticiones y peso para cada uno.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card gt-feature">
                <div class="card-body">
                    <div class="gt-feature-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 3v18h18" />
                            <path d="M19 9l-5 5-4-4-3 3" />
                        </svg>
                    </div>
                    <h5 class="card-title">Progreso real</h5>
                    <p class="text-muted mb-0">
                        Registra tus sesiones y mediciones, y visualiza tu evolución
                        de fuerza y peso con gráficas claras.
                    </p>
                </div>
            </div>
        </div>
    </div>
}