@model GymTracker.Models.Rutina

@{
    ViewData["Title"] = $"Rutina - {Model.Nombre}";
    var ejercicios = Model.Ejercicios.OrderBy(e => e.Orden).ToList();
    var totalSeries = ejercicios.Sum(e => e.SeriesObjetivo);
    var totalGrupos = ejercicios.Select(e => e.Ejercicio.GrupoMuscular).Distinct().Count();
    var gifs = ViewBag.Gifs as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="container mt-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-3">&larr; Volver a Mis Rutinas</a>

    <div class="d-flex flex-wrap gap-3 justify-content-between align-items-start mb-4">
        <div>
            <h1 class="page-title section-accent">@Model.Nombre</h1>
            <p class="page-subtitle">
                Creada el @Model.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
            </p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            @if (ejercicios.Any())
            {
                <form asp-controller="Sesiones" asp-action="Iniciar" method="post" class="d-inline">
                    <input type="hidden" name="rutinaId" value="@Model.Id" />
                    <button type="submit" class="btn btn-success">Iniciar entrenamiento</button>
                </form>
                <button type="button" id="btn-analizar" class="btn btn-secondary">Analizar con IA</button>
            }
            <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
            <a asp-action="Eliminar" asp-route-id="@Model.Id" class="btn btn-outline-danger">Eliminar</a>
        </div>
    </div>

    <!-- Métricas rápidas de la rutina -->
    <div class="row g-3 mb-4">
        <div class="col-4">
            <div class="gt-stat">
                <div class="gt-stat-value">@ejercicios.Count</div>
                <div class="gt-stat-label">Ejercicios</div>
            </div>
        </div>
        <div class="col-4">
            <div class="gt-stat">
                <div class="gt-stat-value">@totalSeries</div>
                <div class="gt-stat-label">Series totales</div>
            </div>
        </div>
        <div class="col-4">
            <div class="gt-stat">
                <div class="gt-stat-value">@totalGrupos</div>
                <div class="gt-stat-label">Grupos musculares</div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Descripcion))
    {
        <div class="card mb-4">
            <div class="card-body">
                <h6 class="card-subtitle mb-2 text-muted">Descripción</h6>
                <p class="card-text mb-0">@Model.Descripcion</p>
            </div>
        </div>
    }

    @if (ejercicios.Any())
    {
        <div id="coach-panel" class="gt-coach-panel d-none">
            <div class="gt-coach-header">
                <h3 class="gt-coach-title">Análisis del entrenador</h3>
                <span class="gt-coach-badge">IA</span>
            </div>
            <div id="coach-contenido"></div>
        </div>
    }

    <h3 class="section-accent mb-3">Ejercicios de esta rutina</h3>

    @if (!ejercicios.Any())
    {
        <div class="alert alert-warning">
            Esta rutina no tiene ejercicios asignados todavía.
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Ejercicio</th>
                            <th>Grupo</th>
                            <th class="text-center">Series</th>
                            <th class="text-center">Reps</th>
                            <th class="text-end">Peso (kg)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ejercicios)
                        {
                            <tr>
                                <td class="text-muted">@(ejercicios.IndexOf(item) + 1)</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        @if (gifs.TryGetValue(item.EjercicioId, out var gifUrl))
                                        {
                                            <img src="@gifUrl" alt="@item.Ejercicio.Nombre"
                                                 class="gt-serie-gif js-abrir-gif"
                                                 data-gif="@gifUrl" data-nombre="@item.Ejercicio.Nombre"
                                                 title="Ver animación" loading="lazy"
                                                 onerror="this.remove()" />
                                        }
                                        <strong>@item.Ejercicio.Nombre</strong>
                                    </div>
                                </td>
                                <td><span class="gt-badge-grupo" data-grupo="@item.Ejercicio.GrupoMuscular">@item.Ejercicio.GrupoMuscular</span></td>
                                <td class="text-center">@item.SeriesObjetivo</td>
                                <td class="text-center">@item.RepeticionesObjetivo</td>
                                <td class="text-end">@item.PesoObjetivo.ToString("0.##")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- Modal: animación del ejercicio (GIF grande) -->
<div class="modal fade" id="modalGif" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-capitalize" id="modalGifTitulo"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body text-center">
                <img id="modalGifImg" src="" alt="" class="gt-cat-detalle-gif" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Modal de animación del ejercicio (GIF).
        (function () {
            const modalEl = document.getElementById('modalGif');
            if (modalEl) {
                const modal = new bootstrap.Modal(modalEl);
                const img = document.getElementById('modalGifImg');
                const titulo = document.getElementById('modalGifTitulo');
                document.querySelectorAll('.js-abrir-gif').forEach(el => {
                    el.addEventListener('click', () => {
                        img.src = el.dataset.gif;
                        img.alt = el.dataset.nombre || '';
                        titulo.textContent = el.dataset.nombre || 'Animación';
                        modal.show();
                    });
                });
            }
        })();
    </script>
    <script>
        const btnAnalizar = document.getElementById('btn-analizar');
        const panel = document.getElementById('coach-panel');
        const contenido = document.getElementById('coach-contenido');
        const rutinaId = @Model.Id;

        if (btnAnalizar) {
            btnAnalizar.addEventListener('click', async () => {
                // Mostrar panel con estado de carga.
                panel.classList.remove('d-none');
                contenido.innerHTML = `
                    <div class="gt-coach-cargando">
                        <span class="gt-coach-spinner"></span>
                        <span>Analizando tu rutina con IA...</span>
                    </div>`;
                btnAnalizar.disabled = true;
                panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

                try {
                    const resp = await fetch('/api/coach/analizar/' + rutinaId, { method: 'POST' });

                    if (!resp.ok) {
                        const err = await resp.json().catch(() => ({}));
                        contenido.innerHTML = `<p class="text-muted mb-0">${err.error || 'No se pudo generar el análisis. Intenta de nuevo.'}</p>`;
                        btnAnalizar.disabled = false;
                        return;
                    }

                    const a = await resp.json();
                    contenido.innerHTML = renderAnalisis(a);
                } catch (e) {
                    contenido.innerHTML = `<p class="text-muted mb-0">Error de conexión. Intenta de nuevo.</p>`;
                } finally {
                    btnAnalizar.disabled = false;
                }
            });
        }

        function escapar(t) {
            const d = document.createElement('div');
            d.textContent = t ?? '';
            return d.innerHTML;
        }

        function renderAnalisis(a) {
            const veredictoClase = a.volumenAdecuado ? 'ok' : 'no';
            const veredictoTexto = a.volumenAdecuado ? 'Volumen adecuado' : 'Volumen a revisar';

            const sugerencias = (a.sugerencias || [])
                .map(s => `<li>${escapar(s)}</li>`).join('');

            const descuidados = (a.gruposDescuidados || [])
                .map(g => `<span class="gt-coach-descuidado">${escapar(g)}</span>`).join('');

            return `
                <div class="gt-coach-seccion">
                    <h4>Balance muscular</h4>
                    <p>${escapar(a.balanceMuscular)}</p>
                </div>

                <div class="gt-coach-veredicto ${veredictoClase}">${veredictoTexto}</div>
                <div class="gt-coach-seccion">
                    <p>${escapar(a.comentarioVolumen)}</p>
                </div>

                ${sugerencias ? `
                <div class="gt-coach-seccion">
                    <h4>Sugerencias</h4>
                    <ul class="gt-coach-lista">${sugerencias}</ul>
                </div>` : ''}

                ${descuidados ? `
                <div class="gt-coach-seccion">
                    <h4>Grupos descuidados</h4>
                    <div>${descuidados}</div>
                </div>` : ''}
            `;
        }
    </script>
}
