@model List<GymTracker.Models.Rutina>

@{
    ViewData["Title"] = "Mis Rutinas";
}

<div class="container mt-4">
    <div class="d-flex flex-wrap gap-2 justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-title section-accent">Mis Rutinas</h1>
            <p class="page-subtitle">Tus rutinas de entrenamiento con sus metas.</p>
        </div>
        <a asp-action="Agregar" class="btn btn-primary">+ Agregar rutina</a>
    </div>

    @if (!Model.Any())
    {
        <div class="gt-empty">
            <div class="gt-empty-icon">📋</div>
            <h5>No tienes rutinas todavía</h5>
            <p>Crea tu primera rutina y empieza a planear tus entrenamientos.</p>
            <a asp-action="Agregar" class="btn btn-primary">+ Crear mi primera rutina</a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var rutina in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 gt-card-link gt-card-accent">
                        <div class="card-body">
                            <h5 class="card-title">@rutina.Nombre</h5>
                            <p class="card-text text-muted small mb-2">
                                Creada el @rutina.FechaCreacion.ToLocalTime().ToString("dd/MM/yyyy")
                            </p>
                            @if (!string.IsNullOrEmpty(rutina.Descripcion))
                            {
                                <p class="card-text">@rutina.Descripcion</p>
                            }
                        </div>
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <div class="gt-acciones justify-content-end">
                                <a asp-action="Detalle" asp-route-id="@rutina.Id" class="gt-accion" title="Ver">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                        <circle cx="12" cy="12" r="3" />
                                    </svg>
                                </a>
                                <a asp-action="Editar" asp-route-id="@rutina.Id" class="gt-accion" title="Editar">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                        <path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                    </svg>
                                </a>
                                <a asp-action="Eliminar" asp-route-id="@rutina.Id" class="gt-accion gt-accion-danger" title="Eliminar">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="3 6 5 6 21 6" />
                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
